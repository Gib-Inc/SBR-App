# ============================================================
# SBR App — Environment Variables
# Copy this to .env and fill in your values
# On Railway: add these in the Variables tab
# ============================================================

# ── Core ─────────────────────────────────────────────────────
DATABASE_URL=                          # Railway provides this automatically when you add Postgres
SESSION_SECRET=                        # Random string for session encryption
PORT=5000                              # Railway sets this automatically
NODE_ENV=production
APP_BASE_URL=                          # Your Railway public URL, e.g. https://sbr-app-production.up.railway.app

# ── Auth ─────────────────────────────────────────────────────
ALLOW_REGISTRATION=false               # Set true for initial setup, then false
SINGLE_USER_MODE=false
PRIMARY_ADMIN_EMAIL=

# ── Anthropic Claude (AI features) ──────────────────────────
ANTHROPIC_API_KEY=

# ── Shopify ──────────────────────────────────────────────────
SHOPIFY_SHOP_DOMAIN=                   # e.g. my-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_SECRET=
SHOPIFY_API_VERSION=2024-01
SHOPIFY_LOCATION_ID=
SHOPIFY_HILDALE_LOCATION_ID=
SHOPIFY_PIVOT_LOCATION_ID=
SHOPIFY_WEBHOOK_URL=                   # e.g. https://your-railway-url.up.railway.app/api/webhooks/shopify

# ── Amazon Seller Central ────────────────────────────────────
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
AMAZON_SELLER_ID=
AMAZON_MARKETPLACE_ID=

# ── GoHighLevel (GHL) ───────────────────────────────────────
GOHIGHLEVEL_API_KEY=
GHL_AGENT_API_KEY=
GHL_WEBHOOK_SECRET=
GHL_PURCHASE_PIPELINE_ID=
GHL_PURCHASE_STAGE_DRAFT_ID=
GHL_NEEDS_ATTENTION_PIPELINE_ID=
GHL_NEEDS_ATTENTION_STAGE_ID=

# ── QuickBooks Online ───────────────────────────────────────
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=               # e.g. https://your-railway-url.up.railway.app/api/quickbooks/callback
QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN=
QB_ENCRYPTION_KEY=                     # 32-char hex string for token encryption

# ── Extensiv (3PL/Warehouse) ────────────────────────────────
EXTENSIV_API_KEY=
EXTENSIV_BASE_URL=
EXTENSIV_WAREHOUSE_ID=
EXTENSIV_PUSH_ORDERS=false
EXTENSIV_WEBHOOK_SECRET=

# ── Shippo (Shipping Labels) ────────────────────────────────
SHIPPO_API_KEY=
SHIPPO_DEFAULT_CARRIER=
SHIPPO_DEFAULT_SERVICE=
SHIPPO_DEFAULT_FROM_ADDRESS=
SHIPPO_DEFAULT_FROM_ADDRESS_LINE=
SHIPPO_DEFAULT_FROM_NAME=
SHIPPO_DEFAULT_FROM_PHONE=
SHIPPO_DEFAULT_FROM_CITY=
SHIPPO_DEFAULT_FROM_STATE=
SHIPPO_DEFAULT_FROM_ZIP=
SHIPPO_DEFAULT_FROM_COUNTRY=US
SHIPPO_WAREHOUSE_NAME=
SHIPPO_WAREHOUSE_STREET=
SHIPPO_WAREHOUSE_CITY=
SHIPPO_WAREHOUSE_STATE=
SHIPPO_WAREHOUSE_ZIP=
SHIPPO_WAREHOUSE_COUNTRY=US
SHIPPO_WAREHOUSE_PHONE=

# ── SendGrid (Email) ────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=

# ── PhantomBuster (Supplier Discovery) ──────────────────────
PHANTOMBUSTER_API_KEY=

# ── Google Ads ───────────────────────────────────────────────
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REDIRECT_URI=

# ── Meta/Facebook Ads ───────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=

# ── Returns (Return-To Address) ──────────────────────────────
RETURN_TO_ADDRESS=
RETURN_TO_NAME=
RETURN_TO_STREET=
RETURN_TO_CITY=
RETURN_TO_STATE=
RETURN_TO_ZIP=
RETURN_TO_PHONE=
RETURN_TO_COUNTRY=US

# ── Warehouse Info (for labels/docs) ────────────────────────
WAREHOUSE_NAME=
WAREHOUSE_STREET=
WAREHOUSE_CITY=
WAREHOUSE_STATE=
WAREHOUSE_ZIP=
WAREHOUSE_COUNTRY=
WAREHOUSE_PHONE=
WAREHOUSE_EMAIL=

# ── Feature Flags ────────────────────────────────────────────
AUTO_SCRAPE_SUPPLIER_PRICES_ENABLED=false
